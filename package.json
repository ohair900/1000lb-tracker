{
  "name": "1000lb-club-tracker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.src.html index.html && rm -rf assets && cp -r dist/assets assets",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:legacy": "node tests.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,css}\" \"*.{js,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\" \"*.{js,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
